{
  "name": "actions",
  "description": "Level 4 action recording test vectors per SPEC §4.3",
  "version": "0.2.0",
  "keys": {
    "golden": {
      "alg": "ES256",
      "pub": "2nTOaFVm2QLxmUO_SjgyscVHBtvHEfo2rq65MvgNRjORojq39Haq9rXNxvXxwba_Xj0F5vZibJR3isBdOWbo5g",
      "tmb": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg"
    }
  },
  "tests": [
    {
      "name": "single_action_promotes_ds",
      "description": "DS = czd for single action (no hash, direct promotion per SPEC §7.4)",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "actions": [
        {
          "pay": {
            "alg": "ES256",
            "msg": "First action",
            "now": 1700000001,
            "tmb": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg",
            "typ": "cyphr.me/action"
          },
          "sig": "wM2Ot72H8U-a5RH6W9xvSy1fHvMmz7YrnS4ksKrZQUFVrpJp_T6G-sVl8K0dPGOB-y0v7M-wnXNB8Qe8oqGQpg",
          "czd": "YB2-pTZdR-JkkzJt46z7dyJ3NIq7kxRPbuIX3JljYoQ"
        }
      ],
      "expected": {
        "ds_equals_czd": true,
        "action_count": 1,
        "ds": "YB2-pTZdR-JkkzJt46z7dyJ3NIq7kxRPbuIX3JljYoQ"
      }
    },
    {
      "name": "multiple_actions_sorted",
      "description": "DS = H(sort(czd₀, czd₁...)) for multiple actions (SPEC §7.4)",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "actions": [
        {
          "pay": {
            "alg": "ES256",
            "msg": "First action",
            "now": 1700000001,
            "tmb": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg",
            "typ": "cyphr.me/action"
          },
          "sig": "wM2Ot72H8U-a5RH6W9xvSy1fHvMmz7YrnS4ksKrZQUFVrpJp_T6G-sVl8K0dPGOB-y0v7M-wnXNB8Qe8oqGQpg",
          "czd": "YB2-pTZdR-JkkzJt46z7dyJ3NIq7kxRPbuIX3JljYoQ"
        },
        {
          "pay": {
            "alg": "ES256",
            "msg": "Second action",
            "now": 1700000002,
            "tmb": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg",
            "typ": "cyphr.me/action"
          },
          "sig": "6166KUG-xLGpIoelQB3yuuv6kS_4bRVVgcuD04fwRN44PnUg5b1c3q2LWXFpUoICQWCOEY04EqNEWluQOgvI8Q",
          "czd": "FDtFSUL52Uc-e9Ul6YDCYvjVA0yHTRa7H6759tWmOpg"
        }
      ],
      "expected": {
        "ds_is_hash": true,
        "action_count": 2
      }
    },
    {
      "name": "action_changes_ps",
      "description": "PS includes DS after action recording (PS changes from AS)",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "actions": [
        {
          "pay": {
            "alg": "ES256",
            "msg": "First action",
            "now": 1700000001,
            "tmb": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg",
            "typ": "cyphr.me/action"
          },
          "sig": "wM2Ot72H8U-a5RH6W9xvSy1fHvMmz7YrnS4ksKrZQUFVrpJp_T6G-sVl8K0dPGOB-y0v7M-wnXNB8Qe8oqGQpg",
          "czd": "YB2-pTZdR-JkkzJt46z7dyJ3NIq7kxRPbuIX3JljYoQ"
        }
      ],
      "expected": {
        "ps_changed": true,
        "ps_includes_ds": true
      }
    },
    {
      "name": "action_updates_last_used",
      "description": "Recording action updates signer key's last_used timestamp",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "actions": [
        {
          "pay": {
            "alg": "ES256",
            "msg": "First action",
            "now": 1700000001,
            "tmb": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg",
            "typ": "cyphr.me/action"
          },
          "sig": "wM2Ot72H8U-a5RH6W9xvSy1fHvMmz7YrnS4ksKrZQUFVrpJp_T6G-sVl8K0dPGOB-y0v7M-wnXNB8Qe8oqGQpg",
          "czd": "YB2-pTZdR-JkkzJt46z7dyJ3NIq7kxRPbuIX3JljYoQ"
        }
      ],
      "expected": {
        "signer_last_used": 1700000001
      }
    },
    {
      "name": "level_upgrades_to_4",
      "description": "Principal upgrades to Level 4 after recording first action",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "actions": [
        {
          "pay": {
            "alg": "ES256",
            "msg": "First action",
            "now": 1700000001,
            "tmb": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg",
            "typ": "cyphr.me/action"
          },
          "sig": "wM2Ot72H8U-a5RH6W9xvSy1fHvMmz7YrnS4ksKrZQUFVrpJp_T6G-sVl8K0dPGOB-y0v7M-wnXNB8Qe8oqGQpg",
          "czd": "YB2-pTZdR-JkkzJt46z7dyJ3NIq7kxRPbuIX3JljYoQ"
        }
      ],
      "expected": {
