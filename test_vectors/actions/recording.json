{
  "name": "actions",
  "description": "Level 4 action recording test vectors per SPEC §4.3",
  "version": "0.1.0",
  "keys": {
    "golden": {
      "alg": "ES256",
      "pub": "2nTOaFVm2QLxmUO_SjgyscVHBtvHEfo2rq65MvgNRjORojq39Haq9rXNxvXxwba_Xj0F5vZibJR3isBdOWbo5g",
      "tmb": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg"
    }
  },
  "tests": [
    {
      "name": "single_action_promotes_ds",
      "description": "DS = czd for single action (no hash, direct promotion per SPEC §7.4)",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "actions": [
        {
          "typ": "cyphr.me/action",
          "now": 1700000001,
          "msg": "First action",
          "czd": "i0SgPM3hrHlOmU0n4wU1Ozf5pmTQGbH90jqbkJ5H394"
        }
      ],
      "expected": {
        "ds_equals_czd": true,
        "action_count": 1,
        "ds": "i0SgPM3hrHlOmU0n4wU1Ozf5pmTQGbH90jqbkJ5H394"
      }
    },
    {
      "name": "multiple_actions_sorted",
      "description": "DS = H(sort(czd₀, czd₁...)) for multiple actions (SPEC §7.4)",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "actions": [
        {
          "typ": "cyphr.me/action",
          "now": 1700000001,
          "msg": "First action",
          "czd": "i0SgPM3hrHlOmU0n4wU1Ozf5pmTQGbH90jqbkJ5H394"
        },
        {
          "typ": "cyphr.me/action",
          "now": 1700000002,
          "msg": "Second action",
          "czd": "FDtFSUL52Uc-e9Ul6YDCYvjVA0yHTRa7H6759tWmOpg"
        }
      ],
      "expected": {
        "ds_is_hash": true,
        "action_count": 2,
        "ds": "mOV2KJsu4ykPeEAgre0bPu3JGxL4uDYMMamBVQqSIwY"
      }
    },
    {
      "name": "action_changes_ps",
      "description": "PS includes DS after action recording (PS changes from AS)",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "actions": [
        {
          "typ": "cyphr.me/action",
          "now": 1700000001,
          "msg": "First action",
          "czd": "i0SgPM3hrHlOmU0n4wU1Ozf5pmTQGbH90jqbkJ5H394"
        }
      ],
      "expected": {
        "ps_changed": true,
        "ps_includes_ds": true,
        "ps": "Lz5GMDvAGNTDWOb4TCfF4FOV0h49WawmtOSPO8xyN2g"
      }
    },
    {
      "name": "action_updates_last_used",
      "description": "Recording action updates signer key's last_used timestamp",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "actions": [
        {
          "typ": "cyphr.me/action",
          "now": 1700000001,
          "msg": "First action",
          "czd": "i0SgPM3hrHlOmU0n4wU1Ozf5pmTQGbH90jqbkJ5H394"
        }
      ],
      "expected": {
        "signer_last_used": 1700000001
      }
    },
    {
      "name": "level_upgrades_to_4",
      "description": "Principal upgrades to Level 4 after recording first action",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "actions": [
        {
          "typ": "cyphr.me/action",
          "now": 1700000001,
          "msg": "First action",
          "czd": "i0SgPM3hrHlOmU0n4wU1Ozf5pmTQGbH90jqbkJ5H394"
        }
      ],
      "expected": {
        "level": 4,
        "has_data_state": true
      }
    }
  ]
}
