{
  "name": "edge_cases",
  "description": "Edge case test vectors per SPEC §7 (State Calculation). Keys resolved from keys/pool.json.",
  "version": "0.2.0",
  "tests": [
    {
      "name": "key_thumbprint_sort_order",
      "description": "Verify KS uses lexicographic byte sort, not string sort (SPEC §7.1, §7.2)",
      "setup": {
        "genesis": "explicit",
        "initial_keys": ["alice", "bob", "carol"]
      },
      "expected": {
        "key_count": 3,
        "ks": "lfyEU2xRWD-KGCxoeMiQk_yAJXGwpI5k5u3-kLpmS1s"
      }
    },
    {
      "name": "same_keys_different_order",
      "description": "Verify KS is idempotent regardless of key addition order (SPEC §7.2)",
      "setup": {
        "genesis": "explicit",
        "initial_keys": ["carol", "alice", "bob"]
      },
      "expected": {
        "key_count": 3,
        "ks": "lfyEU2xRWD-KGCxoeMiQk_yAJXGwpI5k5u3-kLpmS1s"
      }
    },
    {
      "name": "transaction_replay_order",
      "description": "Verify TS depends on transaction application order (SPEC §7.3)",
      "setup": {
        "genesis": "implicit",
        "initial_key": "alice"
      },
      "coz_sequence": [
        {
          "pay": {
            "alg": "ES256",
            "id": "3qiFqQKB-VoG2i8HgH_eHq6PfEIM9fTL1LuUKFoPE-8",
            "now": 1700000001,
            "pre": "1S0fVE6_p3gAX_PBfLncKdDcg7mM9sJMsNNYYC1D7Fw",
            "tmb": "1S0fVE6_p3gAX_PBfLncKdDcg7mM9sJMsNNYYC1D7Fw",
            "typ": "cyphr.me/key/add"
          },
          "key": "bob",
          "sig": "IV7S0229-6kTcCrDJtKKhE30tTDWkuqXhKMz9DKb0YhVqmKpKED6xbz8oP6RUH23vrx3D9G2OXvNvLPBg27dVw",
          "czd": "ZaYLQLe8W_pZJwGJ7SLL3Vlf9sREj0AbjEWXmf0h7dw"
        },
        {
          "pay": {
            "alg": "ES256",
            "id": "3N4zAlQv6-BOeO0hop_dB6GVfalTaT9CIRWxOfUOyRA",
            "now": 1700000002,
            "pre": "i_3yPE3WaqZyUmwx1aT0PmFWpeseLxq0V59iQ7uIQec",
            "tmb": "1S0fVE6_p3gAX_PBfLncKdDcg7mM9sJMsNNYYC1D7Fw",
            "typ": "cyphr.me/key/add"
          },
          "key": "carol",
          "sig": "HKPMVqBiWMSg0uLYwUwM_X3eRJpxuqZ0whv7wgn5I082D1B333mt8SlWSRwHsvSRXyKi8_DMZDYS2Izeu0tdCA",
          "czd": "haDVo_X22xp8HlmhF8DW4tICIbqXZtq-WAF5uojsYVc"
        }
      ],
      "expected": {
        "key_count": 3,
        "ts_is_hash": true
      }
    },
    {
      "name": "action_after_key_add",
      "description": "Verify combined state after transaction + action (SPEC §7.4, §7.5)",
      "setup": {
        "genesis": "implicit",
        "initial_key": "alice"
      },
      "coz": {
        "pay": {
          "alg": "ES256",
          "id": "3qiFqQKB-VoG2i8HgH_eHq6PfEIM9fTL1LuUKFoPE-8",
          "now": 1700000001,
          "pre": "1S0fVE6_p3gAX_PBfLncKdDcg7mM9sJMsNNYYC1D7Fw",
          "tmb": "1S0fVE6_p3gAX_PBfLncKdDcg7mM9sJMsNNYYC1D7Fw",
          "typ": "cyphr.me/key/add"
        },
        "key": "bob",
        "sig": "IV7S0229-6kTcCrDJtKKhE30tTDWkuqXhKMz9DKb0YhVqmKpKED6xbz8oP6RUH23vrx3D9G2OXvNvLPBg27dVw",
        "czd": "ZaYLQLe8W_pZJwGJ7SLL3Vlf9sREj0AbjEWXmf0h7dw"
      },
      "action": {
        "pay": {
          "alg": "ES256",
          "msg": "Action signed by newly added key",
          "now": 1700000002,
          "tmb": "3qiFqQKB-VoG2i8HgH_eHq6PfEIM9fTL1LuUKFoPE-8",
          "typ": "cyphr.me/action"
        },
        "sig": "dMkBTyrVaudkKooREWzGsxVVgeN-0UVzpADitJsEGVIvXJdHHzmHBEsazYNWIetvcedUzHvVOaSwI5U3ys2bIQ",
        "czd": "_bP7uOgFmXhpnATccZAO4lWxShGgjwImHdBWOVYDjxM"
      },
      "expected": {
        "key_count": 2,
        "has_data_state": true,
        "ps_is_hash_of_as_ds": true
      }
    }
  ]
}
