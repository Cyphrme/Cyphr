{
  "name": "explicit_genesis",
  "description": "Explicit multi-key genesis test vectors per SPEC §3.7. Keys resolved from keys/pool.json.",
  "version": "0.2.0",
  "tests": [
    {
      "name": "explicit_genesis_two_keys_es256",
      "description": "Level 3 explicit genesis with two ES256 keys. PR = H(sort(tmb0, tmb1)).",
      "input": {
        "type": "explicit_genesis",
        "keys": ["golden", "key_a"]
      },
      "expected": {
        "pr": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "ps": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "as": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "ks": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "ts": null,
        "ds": null,
        "level": 3,
        "error": null
      }
    },
    {
      "name": "explicit_genesis_alice_bob",
      "description": "Level 3 explicit genesis with alice + bob. Same keys used in multi_key.json tests.",
      "input": {
        "type": "explicit_genesis",
        "keys": ["alice", "bob"]
      },
      "expected": {
        "pr": "2Q4DBjw_u0bfpCpSBJndG5gPY5ltWHrSDflpCC2CIlc",
        "ps": "2Q4DBjw_u0bfpCpSBJndG5gPY5ltWHrSDflpCC2CIlc",
        "as": "2Q4DBjw_u0bfpCpSBJndG5gPY5ltWHrSDflpCC2CIlc",
        "ks": "2Q4DBjw_u0bfpCpSBJndG5gPY5ltWHrSDflpCC2CIlc",
        "ts": null,
        "ds": null,
        "level": 3,
        "error": null
      }
    },
    {
      "name": "explicit_genesis_three_keys",
      "description": "Level 3 explicit genesis with three ES256 keys (alice, bob, carol).",
      "input": {
        "type": "explicit_genesis",
        "keys": ["alice", "bob", "carol"]
      },
      "expected": {
        "pr": "lfyEU2xRWD-KGCxoeMiQk_yAJXGwpI5k5u3-kLpmS1s",
        "ps": "lfyEU2xRWD-KGCxoeMiQk_yAJXGwpI5k5u3-kLpmS1s",
        "as": "lfyEU2xRWD-KGCxoeMiQk_yAJXGwpI5k5u3-kLpmS1s",
        "ks": "lfyEU2xRWD-KGCxoeMiQk_yAJXGwpI5k5u3-kLpmS1s",
        "ts": null,
        "ds": null,
        "level": 3,
        "error": null
      }
    },
    {
      "name": "explicit_genesis_idempotent_order",
      "description": "Idempotency: Keys in different order produce same PR (verifies sorting).",
      "input": {
        "type": "explicit_genesis",
        "keys": ["key_a", "golden"]
      },
      "expected": {
        "pr": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "ps": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "as": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "ks": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "ts": null,
