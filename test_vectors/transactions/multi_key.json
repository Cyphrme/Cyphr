{
  "name": "multi_key_transactions",
  "description": "Multi-key transaction scenarios per SPEC §4.2 - testing operations on accounts with 2+ active keys. Keys resolved from keys/pool.json.",
  "version": "0.1.0",
  "tests": [
    {
      "name": "add_third_key_to_dual_key_account",
      "description": "Adding a key when 2 keys already active should result in 3 active keys",
      "setup": {
        "genesis": "explicit",
        "initial_keys": ["alice", "bob"]
      },
      "coz": {
        "pay": {
          "alg": "ES256",
          "id": "3N4zAlQv6-BOeO0hop_dB6GVfalTaT9CIRWxOfUOyRA",
          "now": 1700000000,
          "pre": "2Q4DBjw_u0bfpCpSBJndG5gPY5ltWHrSDflpCC2CIlc",
          "tmb": "1S0fVE6_p3gAX_PBfLncKdDcg7mM9sJMsNNYYC1D7Fw",
          "typ": "cyphr.me/key/add"
        },
        "key": "carol",
        "sig": "MgHzMdITXPx3ey_Y0lWjxSaxe7sEv_vFnE8gOSqjWMAMISAkCP3NPCNFsRsDBs42oZw2fDn4u68dMWro5UYpOA",
        "czd": "Uaz5MmkBiW7WZQWCld81NT0rauYW9wB48A51xsJrbR8"
      },
      "expected": {
        "key_count": 3,
        "level": 3,
        "active_keys": ["alice", "bob", "carol"]
      }
    },
    {
      "name": "replace_one_of_two_keys",
      "description": "Key replace in 2-key account: replaces signer, other key remains",
      "setup": {
        "genesis": "explicit",
        "initial_keys": ["alice", "bob"]
      },
      "coz": {
        "pay": {
          "alg": "ES256",
          "id": "3N4zAlQv6-BOeO0hop_dB6GVfalTaT9CIRWxOfUOyRA",
          "now": 1700000000,
          "pre": "2Q4DBjw_u0bfpCpSBJndG5gPY5ltWHrSDflpCC2CIlc",
          "tmb": "1S0fVE6_p3gAX_PBfLncKdDcg7mM9sJMsNNYYC1D7Fw",
          "typ": "cyphr.me/key/replace"
        },
        "key": "carol",
        "sig": "vFbUqVMS0hPqGveARDYLLRK9_ERckApcQW6_t1INoxFJs_sMdP1Ck3-fk4Az-UedXlgJoH6SH2BRYfl0nUUDJQ",
        "czd": "DAZLLxWiyEbQNaLUsD3WjM6a3VuU-SYdU-a9GVpR-CI"
      },
      "expected": {
        "key_count": 2,
        "level": 3,
        "active_keys": ["bob", "carol"],
        "signer_active": false
      }
    },
    {
      "name": "non_signer_adds_key",
      "description": "Bob (not genesis key) adds Carol to multi-key account",
      "setup": {
        "genesis": "explicit",
        "initial_keys": ["alice", "bob"]
      },
      "coz": {
        "pay": {
          "alg": "ES256",
          "id": "3N4zAlQv6-BOeO0hop_dB6GVfalTaT9CIRWxOfUOyRA",
          "now": 1700000000,
          "pre": "2Q4DBjw_u0bfpCpSBJndG5gPY5ltWHrSDflpCC2CIlc",
          "tmb": "3qiFqQKB-VoG2i8HgH_eHq6PfEIM9fTL1LuUKFoPE-8",
          "typ": "cyphr.me/key/add"
        },
        "key": "carol",
        "sig": "uBpjiivqx99L3s_ozUBJZ5_Kwj3zdziO_f4fHW1PNc0AWgS5OyUKn5RxS-t69f7Tire70chxJIMvXUptLKrw6Q",
        "czd": "WjorcfuVJ1v1azp2K0ttnrtTgcSmxNaL7OEvMdWFbGA"
      },
      "expected": {
        "key_count": 3,
        "level": 3,
        "active_keys": ["alice", "bob", "carol"]
      }
    },
    {
      "name": "delete_from_triple_key_leaves_two",
      "description": "Deleting one key from 3-key account leaves 2 active keys",
      "setup": {
        "genesis": "explicit",
        "initial_keys": ["alice", "bob", "carol"]
      },
      "coz": {
        "pay": {
          "alg": "ES256",
          "id": "3qiFqQKB-VoG2i8HgH_eHq6PfEIM9fTL1LuUKFoPE-8",
          "now": 1700000000,
          "pre": "lfyEU2xRWD-KGCxoeMiQk_yAJXGwpI5k5u3-kLpmS1s",
          "tmb": "1S0fVE6_p3gAX_PBfLncKdDcg7mM9sJMsNNYYC1D7Fw",
          "typ": "cyphr.me/key/delete"
        },
        "sig": "VYo5HyBTb0p-5axGM1b4GKnTguVYnTNWQHkzQvnyBrZxLYJ3Nc6K0BwX2IHBBgfZtNkOIX7JkjEH-qn4Lzzy8w",
        "czd": "i3okhJsVNoyeGLb7z1GhngxufF7QHkV0o8cBv4f6MWA"
      },
      "expected": {
        "key_count": 2,
        "level": 3,
        "active_keys": ["alice", "carol"]
      }
    }
  ]
}
