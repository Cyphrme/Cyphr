{
  "name": "transactions",
  "description": "Transaction test vectors per SPEC §4.2",
  "version": "0.1.0",
  "keys": {
    "golden": {
      "alg": "ES256",
      "pub": "2nTOaFVm2QLxmUO_SjgyscVHBtvHEfo2rq65MvgNRjORojq39Haq9rXNxvXxwba_Xj0F5vZibJR3isBdOWbo5g",
      "tmb": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg"
    },
    "key_a": {
      "alg": "ES256",
      "pub": "iYGklzRf1A1CqEfxXDgrgcKsZca6GZllIJ_WIE4Pve5cJwf0IyZIY79B_AHSTWxNB9sWhYUPToWF-xuIfFgaAQ",
      "tmb": "CP7cFdWJnEyxobbaa6O5z-Bvd9WLOkfX5QkyGFCqP_M"
    },
    "key_b": {
      "alg": "ES256",
      "pub": "ChVQej503kclgOzJevAXlzQ0kxYh6HYtgaInsQ_ivxB4Dc72qI3cBPJzpjmJn8nven1O0Xc6ntUSd9d5F-1W5Q",
      "tmb": "1tWLpnLAq645dr6p6hQucrLtkJoFtq07YBncOQ-ME8E"
    }
  },
  "tests": [
    {
      "name": "key_add_increases_count",
      "description": "L1→L3 transition: Adding a key to single-key principal increases key count to 2.",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "transaction": {
        "type": "key/add",
        "signer": "golden",
        "add_key": "key_a",
        "now": 1700000000,
        "czd": "dbHppmF2G4V2ZXSLLDxEe5Qr--RBeoWxyLk8oUoaxls"
      },
      "expected": {
        "key_count": 2,
        "level": 3,
        "pr_changed": false,
        "as_changed": true,
        "ps_changed": true,
        "ks": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "as": "SZRYo5Ecm5UfjfqAwOYpyE8YJuxOawbT2WfWDLAvfh8",
        "ps": "SZRYo5Ecm5UfjfqAwOYpyE8YJuxOawbT2WfWDLAvfh8"
      }
    },
    {
      "name": "key_add_changes_state",
      "description": "AS/PS change after key/add, but PR remains constant (permanent identity).",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "transaction": {
        "type": "key/add",
        "signer": "golden",
        "add_key": "key_a",
        "now": 1700000000,
        "czd": "dbHppmF2G4V2ZXSLLDxEe5Qr--RBeoWxyLk8oUoaxls"
      },
      "expected": {
        "pr": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg",
        "pr_changed": false,
        "as_changed": true,
        "ps_changed": true,
        "ks": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "as": "SZRYo5Ecm5UfjfqAwOYpyE8YJuxOawbT2WfWDLAvfh8",
        "ps": "SZRYo5Ecm5UfjfqAwOYpyE8YJuxOawbT2WfWDLAvfh8"
      }
    },
    {
      "name": "key_delete_decreases_count",
      "description": "L3 key removal: Deleting a key decreases key count from 2 to 1.",
      "setup": {
        "genesis": "explicit",
        "initial_keys": ["golden", "key_a"]
      },
      "transaction": {
        "type": "key/delete",
        "signer": "golden",
        "delete_key": "key_a",
        "now": 1700000000,
        "czd": "0pnpK-SpGqFrMo-aG7m030_Wh2kLC3gWcC0Q3AXJjXI"
      },
      "expected": {
        "key_count": 1,
        "level": 3,
        "active_keys": ["golden"],
        "ks": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg",
        "as": "-p8bLAhSvSYtaaokGWCz7ptRl7CVbMB6HSLYw7D_5MQ",
        "ps": "-p8bLAhSvSYtaaokGWCz7ptRl7CVbMB6HSLYw7D_5MQ"
      }
    },
    {
      "name": "key_replace_single_key",
      "description": "L2 atomic swap: Replaces signer key with new key atomically.",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "transaction": {
        "type": "key/replace",
        "signer": "golden",
        "new_key": "key_a",
        "now": 1700000000,
        "czd": "7UpopTQkLdh4D3UCBsax33FjK9XoNGL45b2RF4Cd-e8"
      },
      "expected": {
        "key_count": 1,
        "active_keys": ["key_a"],
        "signer_active": false,
        "pr_changed": false,
        "ks": "CP7cFdWJnEyxobbaa6O5z-Bvd9WLOkfX5QkyGFCqP_M",
        "as": "JiMN8KLwH4BwW6kJDjq1dNaha6KbPLivxOQ8RBLSuMA",
        "ps": "JiMN8KLwH4BwW6kJDjq1dNaha6KbPLivxOQ8RBLSuMA"
      }
    },
    {
      "name": "self_revoke_moves_to_revoked",
      "description": "Self-revoke: Key is moved to revoked set, not fully deleted.",
      "setup": {
        "genesis": "explicit",
        "initial_keys": ["golden", "key_a"]
      },
      "transaction": {
        "type": "key/revoke",
        "signer": "key_a",
        "rvk": 1700000000,
        "now": 1700000000,
        "czd": "Wlu1Hja7-DemNjkelNlWX56AlKmsNXJB9RvZs9b101Y"
      },
      "expected": {
        "key_count": 1,
        "active_keys": ["golden"],
        "revoked_keys": ["key_a"],
        "key_a_rvk": 1700000000,
        "ks": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg",
        "as": "-p8bLAhSvSYtaaokGWCz7ptRl7CVbMB6HSLYw7D_5MQ",
        "ps": "-p8bLAhSvSYtaaokGWCz7ptRl7CVbMB6HSLYw7D_5MQ"
      }
    },
    {
      "name": "other_revoke_by_peer",
      "description": "Cross-key revocation: One active key revokes another.",
      "setup": {
        "genesis": "explicit",
        "initial_keys": ["golden", "key_a"]
      },
      "transaction": {
        "type": "key/revoke",
        "signer": "golden",
        "revoke_key": "key_a",
        "rvk": 1700000000,
        "now": 1700000000,
        "czd": "nPnfEQdbpujJTKlgwc2sGD9BKrGeTG4QJ2ef7fY-Twk"
      },
      "expected": {
        "key_count": 1,
        "active_keys": ["golden"],
        "revoked_keys": ["key_a"],
        "ks": "U5XUZots-WmQYcQWmsO751Xk0yeVi9XUKWQ2mGz6Aqg",
        "as": "-p8bLAhSvSYtaaokGWCz7ptRl7CVbMB6HSLYw7D_5MQ",
        "ps": "-p8bLAhSvSYtaaokGWCz7ptRl7CVbMB6HSLYw7D_5MQ"
      }
    },
    {
      "name": "transaction_sequence_replay",
      "description": "Replay multiple transactions and verify final state matches expected.",
      "setup": {
        "genesis": "implicit",
        "initial_key": "golden"
      },
      "transactions": [
        {
          "type": "key/add",
          "signer": "golden",
          "add_key": "key_a",
          "now": 1700000001,
          "czd": "aLTY8tZcHjdXPUkDWyApz-gBophyOL3438bCGGHr-wo"
        },
        {
          "type": "key/add",
          "signer": "golden",
          "add_key": "key_b",
          "now": 1700000002,
          "czd": "YBD2S6Fu0UMQZznSdF17DGFW0BagnzkctwWTctyuvcc"
        },
        {
          "type": "key/delete",
          "signer": "key_a",
          "delete_key": "key_b",
          "now": 1700000003,
          "czd": "BzDQUaaSflls66rsN3dZTcwxQtZ7asZlkL6dqU0xWmg"
        }
      ],
      "expected": {
        "key_count": 2,
        "active_keys": ["golden", "key_a"],
        "transaction_count": 3,
        "ks": "5fQVYENKNTg8jDH_Yf3hp74yZhToFsYeDhSK5SNGAcc",
        "as": "iYQ6meQjin6quqSmHDNZvhffcwQ1UGHYj0nrZ_P7tUw",
        "ps": "iYQ6meQjin6quqSmHDNZvhffcwQ1UGHYj0nrZ_P7tUw"
      }
    }
  ]
}
