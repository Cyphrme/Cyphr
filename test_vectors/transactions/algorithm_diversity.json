{
  "name": "algorithm_diversity",
  "description": "Transaction tests with ES384 and Ed25519 algorithms to verify hash algorithm selection and cross-algorithm operations (SPEC §7). Keys resolved from keys/pool.json.",
  "version": "0.1.0",
  "tests": [
    {
      "name": "es384_account_adds_es256_key",
      "description": "ES384 principal adds ES256 key. Verifies cross-algorithm key management and SHA-384 hash selection.",
      "setup": {
        "genesis": "implicit",
        "initial_key": "diana_es384"
      },
      "coz": {
        "pay": {
          "alg": "ES384",
          "id": "CP7cFdWJnEyxobbaa6O5z-Bvd9WLOkfX5QkyGFCqP_M",
          "now": 1700000000,
          "pre": "h2HN761WGuS76pKrjLolvENgNlKCx2pQ6lkz6j0ebZOuXLdYG16jBBcLURjSjP_8",
          "tmb": "h2HN761WGuS76pKrjLolvENgNlKCx2pQ6lkz6j0ebZOuXLdYG16jBBcLURjSjP_8",
          "typ": "cyphr.me/key/add"
        },
        "key": "key_a",
        "sig": "9bFm-55jXTAIg3e69ovGUToY_M4ZJ-7XgtSDdSwZA24RKArzZRZqonQNOHWUVbZNMj8KgC9MWKPdxBIxnZTa3ISNieAUt2_GTlel_Dtm8w706gJXORJeYsekKnCY3b8D",
        "czd": "nInzt49Xa7xeSI-B5kMIFk-GS3hArvQCUhQmA5kivYNIzhrS-tJcpZwDVHuYHK6w"
      },
      "expected": {
        "key_count": 2,
        "level": 3,
        "pr_changed": false,
        "as_changed": true,
        "ps_changed": true
      }
    },
    {
      "name": "ed25519_account_adds_es256_key",
      "description": "Ed25519 principal adds ES256 key. Verifies cross-algorithm key management and SHA-512 hash selection.",
      "setup": {
        "genesis": "implicit",
        "initial_key": "eve_ed25519"
      },
      "coz": {
        "pay": {
          "alg": "Ed25519",
          "id": "CP7cFdWJnEyxobbaa6O5z-Bvd9WLOkfX5QkyGFCqP_M",
          "now": 1700000000,
          "pre": "eVTL02eZqLWy_Czxcpol1MPFn7YCHz34V-xy0EAwHjVa73x3MjiE-q0VWCOPS3ChT0_67eA-w_zSGuhJJAMjVQ",
          "tmb": "eVTL02eZqLWy_Czxcpol1MPFn7YCHz34V-xy0EAwHjVa73x3MjiE-q0VWCOPS3ChT0_67eA-w_zSGuhJJAMjVQ",
          "typ": "cyphr.me/key/add"
        },
        "key": "key_a",
        "sig": "ct6L2qyKJdeBagehCcR1sopAjjxQmno11Z_-tFfYulcu5_zFKfnXHgZ7RMKx9N9gWjnz6h_C6Z87iubmzjq6AQ",
        "czd": "1Rj7CKt5LwCSyXDo5he3CoXjdvFCQeY9eDTr7wqKuAAGis-ZwHg_1sKJIrhTsa5o683ilH4B2IRdJVMuqZFUZQ"
      },
      "expected": {
        "key_count": 2,
        "level": 3,
        "pr_changed": false,
        "as_changed": true,
        "ps_changed": true
      }
    }
  ]
}
